# Aegis — variables d'environnement (aucun secret)

# Chemin du socket Unix local daemon <-> UI
AEGIS_SOCKET_PATH=/run/aegis/aegis.sock

# Port WebSocket local du bridge UI (localhost uniquement, jamais exposé)
AEGIS_WS_PORT=8787

# Niveau de log (trace|debug|info|warn|error)
AEGIS_LOG_LEVEL=info

# Mode par défaut au démarrage (detection|prevention)
AEGIS_DEFAULT_MODE=detection
